# Unimed Ourinhos - Credenciais do portal
UNIMED_CPF=000.000.000-00
UNIMED_PASSWORD=sua_senha_aqui

# WhatsApp - Nome exato do grupo onde o boleto será enviado
WHATSAPP_GROUP_NAME=Nome do Grupo Aqui

# Cron schedule (padrão: a cada hora nos dias 5 e 6 de cada mês)
# Formato: segundos minutos horas dia-do-mês mês dia-da-semana
# Controle de mês evita envios duplicados; dia 6 é fallback caso o computador
# não estivesse ligado no dia 5.
CRON_SCHEDULE=0 0 * 5,6 * *

# Diretório para salvar o PDF do boleto (padrão: ./downloads)
DOWNLOAD_DIR=./downloads
